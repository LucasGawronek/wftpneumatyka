{
  "kind": "collectionType",
  "collectionName": "quote_requests",
  "info": {
    "singularName": "quote-request",
    "pluralName": "quote-requests",
    "displayName": "Quote Request",
    "description": "Zapytania przesylane z formularza wyceny"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "customerName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "message": {
      "type": "text",
      "required": true
    },
    "consent": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "new",
        "contacted",
        "offered",
        "closed"
      ],
      "default": "new"
    },
    "productName": {
      "type": "string"
    },
    "productSlug": {
      "type": "string"
    },
    "productPartNumber": {
      "type": "string"
    },
    "requestLocale": {
      "type": "string"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "quoteRequests"
    }
  }
}
