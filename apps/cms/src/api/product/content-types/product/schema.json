{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Produkt",
    "description": "Produkty dostepne w katalogu"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "displayName": "Nazwa",
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "displayName": "Slug",
      "type": "uid",
      "targetField": "name",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "partNumber": {
      "displayName": "Numer czesci",
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "brand": {
      "displayName": "Marka",
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "shortDescription": {
      "displayName": "Krotki opis",
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "displayName": "Opis",
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "specifications": {
      "displayName": "Specyfikacja",
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "featured": {
      "displayName": "Polecany",
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "sortOrder": {
      "displayName": "Kolejnosc sortowania",
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "mainImage": {
      "displayName": "Zdjecie glowne",
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "gallery": {
      "displayName": "Galeria",
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "category": {
      "displayName": "Kategoria",
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "quoteRequests": {
      "displayName": "Zapytania ofertowe",
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quote-request.quote-request",
      "mappedBy": "product",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
